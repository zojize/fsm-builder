{
  "name": "@zojize/fsm-builder",
  "type": "module",
  "version": "0.0.1",
  "description": "Interactive SVG-based FSM (Finite State Machine) builder library",
  "license": "MIT",
  "keywords": [
    "fsm",
    "finite-state-machine",
    "svg",
    "interactive"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "development": "./index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/fsm-builder.js"
    },
    "./style.css": "./dist/fsm-builder.css"
  },
  "main": "./dist/fsm-builder.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build",
    "release": "bumpp && npm publish"
  },
  "devDependencies": {
    "@iconify-json/bi": "^1.2.7",
    "@types/node": "^22.19.15",
    "bumpp": "^11.0.1",
    "happy-dom": "^20.8.9",
    "typescript": "^6.0.2",
    "unocss": "^66.5.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
