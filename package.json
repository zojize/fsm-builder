{
  "name": "fsm-builder-monorepo",
  "type": "module",
  "version": "0.3.5",
  "private": true,
  "workspaces": [
    "src",
    "playground"
  ],
  "scripts": {
    "build": "bun run build:lib && bun run build:playground",
    "build:lib": "bun run --cwd src build",
    "build:playground": "bun run --cwd playground build",
    "dev": "bun run --cwd playground dev",
    "test": "bun run --cwd src test",
    "lint": "eslint .",
    "typecheck": "bun run --filter='*' typecheck",
    "up": "taze major -I",
    "postinstall": "lefthook install"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-plugin-format": "^2.0.1",
    "lefthook": "^2.1.4",
    "lint-staged": "^16.4.0",
    "peggy": "^5.1.0",
    "taze": "^19.10.0",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
